{
  "name": "chinacode",
  "version": "0.1.0",
  "description": "Open-source coding agent for Chinese LLMs (Qwen, DeepSeek, MiMo)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chinacode": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "diff": "^7.0.0",
    "openai": "^4.100.0",
    "ora": "^8.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "cli",
    "ai",
    "agent",
    "qwen",
    "deepseek",
    "llm",
    "chinese-ai"
  ]
}
