{
  "name": "chinacode-cli",
  "version": "0.1.0",
  "description": "Open-source autonomous coding agent CLI optimized for Chinese LLMs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chinacode": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:quick": "vitest run --testPathPattern='unit'",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.3",
    "openai": "^4.47.1",
    "ora": "^8.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.5.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
